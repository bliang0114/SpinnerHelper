<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>cn.github.SpinnerHelper</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>SpinnerHelper</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://gitee.com/bliang0114/SpinnerHelper">BD Team One</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-description -->
    <description>
        SpinnerHelper is a professional plugin designed for IntelliJ IDEA to enhance 3DE development efficiency.
        It optimizes the development experience through intelligent deployment processes and a rich set of auxiliary tools.
        <![CDATA[
        <h2>SpinnerHelper - 3DE开发效率提升插件</h2>
        <p><code>SpinnerHelper</code> 是一款专为 IntelliJ IDEA 设计的专业级插件，致力于优化 3DE 开发体验。通过智能化的部署流程和丰富的辅助工具集，显著提升开发效率与便捷性。</p>
        <p><strong>驱动下载地址:</strong><a href="https://gitee.com/bliang0114/SpinnerHelper/releases/download/2.0.8/matrix-connector-1.1.0.jar">matrix-connector-1.1.0.jar</a></p>
        <p><strong>驱动下载地址:</strong><a href="https://gitee.com/bliang0114/SpinnerHelper/releases/download/2.0.9/matrix-connector-1.2.0.jar">(latest) matrix-connector-1.2.0.jar</a></p>
        <h3>🚀 核心功能</h3>
        <h4>多环境管理</h4>
        <ul>
          <li><strong>多版本支持</strong>：灵活配置不同 3DE 版本环境</li>
          <li><strong>环境切换</strong>：一键实现在不同开发环境间的无缝切换</li>
        </ul>
        <h4>快速部署</h4>
        <ul>
          <li><strong>Spinner 文件部署</strong>：通过右键菜单快速执行配置文件的增量或全量部署</li>
          <li><strong>JPO 文件部署</strong>：提供完整的 JPO 文件部署支持</li>
        </ul>
        <h4>实用工具集</h4>
        <ul>
          <li><strong>MQL Console</strong>：集成化控制台，直接执行 MQL 命令</li>
          <li><strong>URL Parameter Parse</strong>：便捷的 URL 参数解析功能</li>
        </ul>
        <h3>⚙️ 技术特性</h3>
        <p>优化了 <code>EnoBrowserJPO</code> 的 <code>runScript</code> 方法，以获得更好的日志反馈：</p>
        <pre><code>
        public String runScript(Context ctx, String[] args) throws Exception {
            if (adminOnly)
                checkAdmin(ctx);
            String[] cmdarray = Arrays.copyOf(args, args.length - 2);
            String dir = args[args.length - 2];
            String output = args[args.length - 1];
            ProcessBuilder pb = new ProcessBuilder(cmdarray);
            pb.directory(new File(dir));
            pb.redirectErrorStream(true);
            Process p = pb.start();
            StreamWriter sw = new StreamWriter(p.getInputStream(), output);
            sw.run();
            return readFile(ctx, new String[]{output});
        }
        </code></pre>
        <h3>📋 配置要求</h3>
        <ul>
          <li><strong>IDEA 版本</strong>：仅支持 IntelliJ IDEA 2025.1 及以上版本</li>
          <li><strong>依赖准备</strong>：需自行准备对应 3DE 版本的依赖包</li>
        </ul>
    ]]>
    </description>

    <change-notes><![CDATA[
        <h2>3.0.0</h2>
        <ul>
        <li>MQL编辑器已重构为分栏视图：左侧源码、右侧执行结果，替换旧版结果工具窗口。</li>
        <li>执行结果现已保留语句与输出映射、长期历史记录、换行切换、检索功能、语法高亮输出、侧边标记及失败提示气泡。</li>
        <li>针对包含 $1、$2 等占位符的MQL命令，新增非阻塞式执行前弹窗录入。</li>
        <li>环境管理新增CAS开关（新增/编辑/复制流程均支持），适配CAS与非CAS服务器的连接、重连逻辑。</li>
        <li>优化了历史环境配置兼容性，并精细化优化多项MQL编辑器与执行交互体验。</li>
        </ul>
    ]]></change-notes>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends> <!-- 添加这一行 -->
    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="SpinnerConfig" factoryClass="cn.github.spinner.ui.SpinnerUIFactory" anchor="right"
                    icon="AllIcons.RunConfigurations.Remote"/>
        <notificationGroup displayType="BALLOON" id="spinnerNotifier" isLogByDefault="true"
                           bundle="messages.ActionBundles" key="notification.group.spinnernotifier"/>
        <applicationService serviceImplementation="cn.github.spinner.config.SpinnerSettings"/>
        <applicationService serviceImplementation="cn.github.spinner.config.MatrixDriversConfig"/>
        <!-- MQL语言支持 -->
        <fileType name="MQL File"
                  implementationClass="cn.github.spinner.editor.MQLFileType"
                  fieldName="INSTANCE"
                  language="MQL"
                  extensions="mql"/>

        <lang.parserDefinition language="MQL"
                               implementationClass="cn.github.spinner.editor.parser.MQLParserDefinition"/>

        <lang.syntaxHighlighterFactory language="MQL"
                                       implementationClass="cn.github.spinner.editor.highlights.MQLSyntaxHighlighterFactory"/>

        <completion.contributor language="MQL"
                                implementationClass="cn.github.spinner.editor.completion.MQLCompletionContributor"/>

        <colorSettingsPage implementation="cn.github.spinner.editor.highlights.MQLColorSettingsPage"/>

        <fileEditorProvider implementation="cn.github.spinner.editor.ui.MatrixCommonViewProvider"/>
        <fileEditorProvider implementation="cn.github.spinner.editor.spinner.SpinnerDataViewProvider"/>
        <fileEditorProvider implementation="cn.github.spinner.editor.MQLSplitEditorProvider"/>
        <editorNotificationProvider implementation="cn.github.spinner.editor.MQLEditorNotificationProvider"/>
    </extensions>
    <actions>
