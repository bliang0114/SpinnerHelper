                text="SpinnerDeploy"
                icon="AllIcons.Actions.Upload">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="first"/>
            <add-to-group group-id="Vcs.Log.ChangesBrowser.Popup" anchor="first"/>
        </action>
